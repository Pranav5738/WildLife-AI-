# Spring Boot Configuration
SPRING_PROFILES_ACTIVE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false

# Database Configuration (PostgreSQL)
# DATABASE_URL=jdbc:postgresql://localhost:5432/wildlife
# POSTGRES_URL=jdbc:postgresql://localhost:5432/wildlife
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=password
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/wildlife
# SPRING_DATASOURCE_USERNAME=postgres
# SPRING_DATASOURCE_PASSWORD=password

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# AWS S3 Configuration (for image/file uploads)
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET_NAME=wildlife-ai-bucket

# Twilio Configuration (for SMS alerts)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# Application Settings
SERVER_PORT=8080
SERVER_SERVLET_CONTEXT_PATH=/api

# Logging
LOGGING_LEVEL_ROOT=INFO
LOGGING_LEVEL_COM_EXAMPLE_WILDLIFE=DEBUG
